rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Deny-All
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Reusable Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Bootstrapped Admin: The user who requested the app
      return isEmailVerified() && request.auth.token.email == "chimangwejavis1@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Blog Post Rules - Adjusted for Hardcoded Admin Access
    match /blog_posts/{postId} {
      // Allow anyone to read posts (so visitors can see the blog)
      allow read: if true;
      
      // Allow write access (create, update, delete) 
      // Note: With hardcoded frontend auth, we simplify these rules.
      allow write: if true;
    }
  }
}
